<?php
/**
 * Copia este archivo como:
 *   includes/secrets.php
 * o:
 *   includes/secrets.local.php
 * y reemplaza los valores por los de tu hosting.
 *
 * IMPORTANTE:
 * - `includes/secrets.php` esta ignorado por git para no exponer claves.
 * - `includes/secrets.local.php` tambien esta ignorado por git.
 * - No subas este archivo con datos reales a repositorios publicos.
 *
 * Opcional:
 * - Define APP_ENV=production en tu hosting.
 * - Si quieres usar otra ruta de secretos, define MCE_SECRETS_FILE
 *   (ejemplo: /home/usuario/private/mce-secrets.php)
 */

// =========================
// Base de datos (MySQL)
// =========================
$DB_HOST = '127.0.0.1';
$DB_USER = 'TU_USUARIO_DB';
$DB_PASS = 'TU_PASSWORD_DB';
$DB_NAME = 'TU_BASE_DE_DATOS';
$DB_PORT = 3306;
$DB_SOCKET = null; // Ejemplo Linux: '/var/run/mysqld/mysqld.sock'

// =========================
// SMTP (correo saliente)
// =========================
$SMTP_USER = 'contacto@proyectosmce.com';
$SMTP_PASS = 'TU_PASSWORD_O_APP_PASSWORD';
$SMTP_HOST = 'smtp.hostinger.com';
$SMTP_PORT = 587;
$SMTP_SECURE = 'tls'; // tls | ssl
$SMTP_FROM_EMAIL = 'contacto@proyectosmce.com';
$SMTP_FROM_NAME = 'Proyectos MCE';
$SMTP_TO_EMAIL = 'contacto@proyectosmce.com';
$SMTP_DEBUG = false; // true para depurar envios

// =========================
// Google reCAPTCHA v2
// =========================
$RECAPTCHA_SITE_KEY = 'TU_RECAPTCHA_SITE_KEY';
$RECAPTCHA_SECRET_KEY = 'TU_RECAPTCHA_SECRET_KEY';

// =========================
// Extras opcionales
// =========================
$WHATSAPP_VERIFY_TOKEN = 'TU_TOKEN_WEBHOOK_WHATSAPP';
